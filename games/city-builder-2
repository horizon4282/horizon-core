        <div class="legend-item"><span class="swatch" style="background:var(--res)"></span><span data-pt="Residencial" data-en="Residential">Residencial</span></div>
        <div class="legend-item"><span class="swatch" style="background:var(--com)"></span><span data-pt="Comercial" data-en="Commercial">Comercial</span></div>
        <div class="legend-item"><span class="swatch" style="background:var(--ind)"></span><span data-pt="Industrial" data-en="Industrial">Industrial</span></div>
        <div class="legend-item"><span class="swatch" style="background:var(--power)"></span><span data-pt="Energia" data-en="Power">Energia</span></div>
        <div class="legend-item"><span class="swatch" style="background:var(--water)"></span><span data-pt="Água" data-en="Water">Água</span></div>
        <div class="legend-item"><span class="swatch" style="background:var(--school)"></span><span data-pt="Escola" data-en="School">Escola</span></div>
        <div class="legend-item"><span class="swatch" style="background:var(--hospital)"></span><span data-pt="Hospital" data-en="Hospital">Hospital</span></div>
        <div class="legend-item"><span class="swatch" style="background:var(--park)"></span><span data-pt="Parque" data-en="Park">Parque</span></div>
        <div class="legend-item"><span class="swatch" style="background:var(--research)"></span><span data-pt="Pesquisa" data-en="Research">Pesquisa</span></div>
        <div class="legend-item"><span class="swatch" style="background:var(--university)"></span><span data-pt="Universidade" data-en="University">Universidade</span></div>
      </div>
    </aside>

  </section>

  <footer>Studio 4282 · Horizon City Builder Level 2 · Human + AI Creative Laboratory</footer>

</main>

<div id="helpModal" class="modal-overlay">
  <div class="modal-window">
    <div class="modal-header">
      <h2 id="helpTitle">GUIA LEVEL 2</h2>
      <button class="modal-close" onclick="closeHelpModal()">✕</button>
    </div>

    <div class="modal-content" id="helpContent"></div>
  </div>
</div>

<script>
const GRID_SIZE = 18;
const TOTAL_CELLS = GRID_SIZE * GRID_SIZE;

let currentLang = localStorage.getItem("horizonLanguage") || "pt";
let currentTool = "grass";

let money = 1200;
let population = 0;
let revenue = 0;
let happiness = 100;
let pollution = 0;
let education = 0;
let health = 0;
let cycle = 0;
let cityMap = Array(TOTAL_CELLS).fill("grass");

const costs = {
  grass:10,
  road:20,
  residential:100,
  commercial:150,
  industrial:200,
  power:300,
  water:250,
  school:350,
  hospital:450,
  park:180,
  airport:900,
  port:750,
  tourism:400,
  research:650,
  university:800
};

const emojis = {
  grass:"",
  road:"═",
  residential:"🏠",
  commercial:"🏢",
  industrial:"🏭",
  power:"⚡",
  water:"💧",
  school:"🏫",
  hospital:"🏥",
  park:"🌳",
  airport:"✈️",
  port:"🚢",
  tourism:"🏖️",
  research:"🔬",
  university:"🎓"
};

const grid = document.getElementById("grid");

function t(pt,en){
  return currentLang === "pt" ? pt : en;
}

function setLanguage(lang){
  currentLang = lang;
  document.documentElement.lang = lang === "pt" ? "pt-BR" : "en";

  document.getElementById("ptBtn").classList.toggle("active", lang === "pt");
  document.getElementById("enBtn").classList.toggle("active", lang === "en");

  document.querySelectorAll("[data-pt][data-en]").forEach(el=>{
    el.innerHTML = el.dataset[lang];
  });

  localStorage.setItem("horizonLanguage", lang);
  updateDashboard();
}

function setMessage(pt,en){
  document.getElementById("message").textContent = t(pt,en);
}

document.querySelectorAll(".tool").forEach(btn=>{
  btn.addEventListener("click",()=>{
    document.querySelectorAll(".tool").forEach(b=>b.classList.remove("active"));
    btn.classList.add("active");
    currentTool = btn.dataset.tool;
    setMessage("Ferramenta selecionada.", "Selected tool.");
  });
});

function createGrid(){
  grid.innerHTML = "";

  cityMap.forEach((type,index)=>{
    const cell = document.createElement("div");
    cell.className = "cell";
    cell.dataset.index = index;
    cell.addEventListener("click",()=>handleCellClick(index));
    grid.appendChild(cell);
  });

  renderGrid();
}

function renderGrid(){
  document.querySelectorAll(".cell").forEach((cell,index)=>{
    const type = cityMap[index];

    cell.className = "cell";

    if(type !== "grass"){
      cell.classList.add(type);
    }

    if(isZone(type) && !isConnected(index)){
      cell.classList.add("disconnected");
    }

    if(type === "industrial"){
      cell.classList.add("polluted");
    }

    cell.textContent = emojis[type] || "";
  });
}

function handleCellClick(index){
  if(cityMap[index] === currentTool) return;

  const cost = costs[currentTool];

  if(money < cost){
    setMessage("Dinheiro insuficiente.", "Not enough money.");
    return;
  }

  money -= cost;
  cityMap[index] = currentTool;

  calculateCity();
  renderGrid();
  updateDashboard();
  saveGame(false);
}

function isZone(type){
  return ["residential","commercial","industrial"].includes(type);
}

function needsRoad(type){
  return !["grass","road","power","water","park"].includes(type);
}

function neighbors(index){
  const row = Math.floor(index / GRID_SIZE);
  const col = index % GRID_SIZE;
  const list = [];

  if(row > 0) list.push(index - GRID_SIZE);
  if(row < GRID_SIZE - 1) list.push(index + GRID_SIZE);
  if(col > 0) list.push(index - 1);
  if(col < GRID_SIZE - 1) list.push(index + 1);

  return list;
}

function isConnected(index){
  return neighbors(index).some(i=>cityMap[i] === "road");
}

function count(type){
  return cityMap.filter(cell=>cell === type).length;
}

function activeCount(type){
  return cityMap.reduce((total,cell,index)=>{
    if(cell === type){
      if(needsRoad(type)){
        return isConnected(index) ? total + 1 : total;
      }

      return total + 1;
    }

    return total;
  },0);
}

function calculateCity(){
  const res = activeCount("residential");
  const com = activeCount("commercial");
  const ind = activeCount("industrial");
  const roads = count("road");

  const schools = activeCount("school");
  const hospitals = activeCount("hospital");
  const parks = count("park");
  const airports = activeCount("airport");
  const ports = activeCount("port");
  const tourism = activeCount("tourism");
  const research = activeCount("research");
  const universities = activeCount("university");

  const hasPower = count("power") > 0;
  const hasWater = count("water") > 0;

  education = Math.min(100, Math.round((schools * 18) + (universities * 24) + (research * 12)));
  health = Math.min(100, Math.round((hospitals * 28) + (parks * 6)));

  pollution = Math.min(100, Math.round((ind * 8) + (airports * 5) + (ports * 4) - (parks * 4)));
  pollution = Math.max(0, pollution);

  happiness = 100;

  if(!hasPower) happiness -= 25;
  if(!hasWater) happiness -= 25;

  happiness -= pollution * .35;
  happiness += parks * 4;
  happiness += health * .18;
  happiness += education * .12;
  happiness -= Math.max(0, roads - 70) * .10;

  happiness = Math.max(5, Math.min(140, Math.round(happiness)));

  const serviceMultiplier = hasPower && hasWater ? 1 : .45;
  const happinessMultiplier = happiness / 100;
  const educationMultiplier = 1 + (education / 250);
  const healthMultiplier = 1 + (health / 300);

  population = Math.floor(
    res * 14 *
    serviceMultiplier *
    happinessMultiplier *
    healthMultiplier
  );

  const advancedEconomy =
    (airports * 90) +
    (ports * 80) +
    (tourism * (45 + parks * 5)) +
    (research * (70 + education * .6)) +
    (universities * (65 + education * .5));

  const baseRevenue =
    (res * 6) +
    (com * 32) +
    (ind * 55) +
    advancedEconomy -
    (roads * 1) -
    (count("power") * 12) -
    (count("water") * 10) -
    (schools * 18) -
    (hospitals * 26) -
    (parks * 6) -
    (airports * 50) -
    (ports * 42) -
    (research * 35) -
    (universities * 45);

  const populationBonus = population > 250 ? 1.15 : 1;
  const techBonus = research > 0 && universities > 0 ? 1.25 : 1;
  const tourismBonus = tourism > 0 && (airports > 0 || ports > 0) ? 1.25 : 1;

  revenue = Math.floor(
    baseRevenue *
    serviceMultiplier *
    (0.50 + happinessMultiplier) *
    educationMultiplier *
    populationBonus *
    techBonus *
    tourismBonus
  );
}

function updateDashboard(){
  document.getElementById("money").textContent = money;
  document.getElementById("population").textContent = population;
  document.getElementById("revenue").textContent = revenue >= 0 ? "+" + revenue : revenue;
  document.getElementById("happiness").textContent = happiness;
  document.getElementById("pollution").textContent = pollution;
  document.getElementById("education").textContent = education;
  document.getElementById("health").textContent = health;
  document.getElementById("cycle").textContent = cycle;
}

setInterval(()=>{
  cycle++;
  calculateCity();
  money += revenue;
  renderGrid();
  updateDashboard();
  saveGame(false);
},4000);

function saveGame(showAlert=true){
  const data = {
    money,
    population,
    revenue,
    happiness,
    pollution,
    education,
    health,
    cycle,
    cityMap
  };

  localStorage.setItem("horizon_city_builder_level_2", JSON.stringify(data));

  if(showAlert){
    setMessage("Cidade salva localmente.", "City saved locally.");
  }
}

function loadGame(){
  const saved = localStorage.getItem("horizon_city_builder_level_2");

  if(saved){
    try{
      const data = JSON.parse(saved);

      money = data.money ?? 1200;
      population = data.population ?? 0;
      revenue = data.revenue ?? 0;
      happiness = data.happiness ?? 100;
      pollution = data.pollution ?? 0;
      education = data.education ?? 0;
      health = data.health ?? 0;
      cycle = data.cycle ?? 0;

      cityMap = Array.isArray(data.cityMap) && data.cityMap.length === TOTAL_CELLS
        ? data.cityMap
        : Array(TOTAL_CELLS).fill("grass");
    }catch(e){
      cityMap = Array(TOTAL_CELLS).fill("grass");
    }
  }

  calculateCity();
  createGrid();
  updateDashboard();
}

function resetGame(){
  const ok = confirm(t("Resetar a cidade Level 2?", "Reset Level 2 city?"));

  if(!ok) return;

  money = 1200;
  population = 0;
  revenue = 0;
  happiness = 100;
  pollution = 0;
  education = 0;
  health = 0;
  cycle = 0;
  cityMap = Array(TOTAL_CELLS).fill("grass");

  localStorage.removeItem("horizon_city_builder_level_2");

  calculateCity();
  createGrid();
  updateDashboard();
  setMessage("Cidade resetada.", "City reset.");
}

setLanguage(currentLang);
loadGame();

